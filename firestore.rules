rules_version = '2';

// Regras iniciais — ajuste antes de ir para producao.
// Enquanto o app usa API local (etapa 1), estas regras protegem o Firestore apos a migracao.
service cloud.firestore {
  match /databases/{database}/documents {

    match /_meta/{doc} {
      allow read: if false;
      allow write: if false;
    }

    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if false;

      match /equipamentos/{equipId} {
        allow read: if true;
        allow write: if false;
      }

      match /visitas/{visitaId} {
        allow read: if true;
        allow write: if false;
      }

      match /clientes/{clienteId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /usuarios/{uid} {
        allow read, write: if false;
      }
    }

    match /plataforma/{doc}/{collection}/{itemId} {
      allow read, write: if false;
    }
  }
}
